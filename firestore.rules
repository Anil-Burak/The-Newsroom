rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // News pool: read by anyone authenticated, write only by admin
    match /news_pool/{newsId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // Personas: read by anyone authenticated, custom personas writable by creator
    match /personas/{personaId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null 
                    && resource.data.isDefault == false;
    }

    // Player logs: only accessible by the owning user
    match /player_logs/{sessionId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null 
                    && request.auth.uid == request.resource.data.userId;
    }
  }
}
